<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ 시스템 스플래시: 중앙 앱 아이콘 + 하단 TENTENS 워드마크(브랜딩 이미지) -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="windowSplashScreenBackground">@color/brandDark</item>
        <!-- 중앙 아이콘: 여백 포함 X 로고 (기본 앱 아이콘보다 작게 보이도록) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="android:windowSplashScreenBrandingImage">@drawable/splash_branding</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
